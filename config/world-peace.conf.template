[Rule]
# 局域网规则最优先
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Shadowrocket/Lan/Lan.list,DIRECT

# 增加 iCloud Private Relay 拦截
DOMAIN,mask.icloud.com,REJECT
DOMAIN,mask-h2.icloud.com,REJECT

# GitHub 远程规则下载防死锁保障
DOMAIN-SUFFIX,github.com,GitHub
DOMAIN-SUFFIX,githubusercontent.com,GitHub
DOMAIN-SUFFIX,githubassets.com,GitHub

# 个人规则优先（完美配合自动化脚本 build.sh 进行占位符变量替换）
RULE-SET,{{RAW_BASE_URL}}/rules/reject.list,REJECT
RULE-SET,{{RAW_BASE_URL}}/rules/direct.list,DIRECT
RULE-SET,{{RAW_BASE_URL}}/rules/ai.list,AI
RULE-SET,{{RAW_BASE_URL}}/rules/proxy.list,PROXY

# 微信输入法（仅公司网络需要）
DOMAIN,wetype.weixin.qq.com,PROXY

